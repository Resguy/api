SELECT * FROM Customers;

SELECT
    o.OrderID,
    SUM(pm.Quantity * m.Price) AS TotalOrderCost
FROM Orders o
JOIN OrderPositions op ON o.OrderID = op.OrderID
JOIN Products p ON op.ProductID = p.ProductID
JOIN ProductMaterials pm ON p.ProductID = pm.ProductID
JOIN Materials m ON pm.MaterialID = m.MaterialID
WHERE o.OrderID = 1  -- Укажите нужный ID заказа
GROUP BY o.OrderID;
