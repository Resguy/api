using Avalonia.Controls;
using Avalonia.Interactivity;
using DEMO.Models;
using System;
using System.Linq;
using MsgBox = MsBox.Avalonia.MessageBoxManager;
using MsgButton = MsBox.Avalonia.Enums.ButtonEnum;
using MsgIcon = MsBox.Avalonia.Enums.Icon;

namespace DEMO;

public partial class UserWindow : Window
{
    private readonly AppDbContext _context = new();

    private readonly User _currentUser;

    public UserWindow(User? currentUser = null)
    {
        InitializeComponent();

        CmbRoles.ItemsSource = _context.Roles.ToList();

        _currentUser = currentUser ?? new User();

        if (_currentUser.Role != null)
        {
            var userRole = _context.Roles.FirstOrDefault(r => r.Id == _currentUser.Role.Id);
            CmbRoles.SelectedItem = userRole;
        }
        else
        {
            CmbRoles.SelectedIndex = 0;
        }

        DataContext = _currentUser;
    }

    private void Button_Click(object? sender, RoutedEventArgs e)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(_currentUser.LastName) ||
                string.IsNullOrWhiteSpace(_currentUser.FirstName) ||
                string.IsNullOrWhiteSpace(_currentUser.MiddleName) ||
                string.IsNullOrWhiteSpace(_currentUser.Login) ||
                string.IsNullOrWhiteSpace(_currentUser.Password))
            {
                MsgBox
                    .GetMessageBoxStandard("Ошибка", "Заполните все поля.", MsgButton.Ok, MsgIcon.Info)
                    .ShowWindowDialogAsync(this);

                return;
            }

            if (CmbRoles.SelectedItem is not Role selectedRole)
            {
                MsgBox
                    .GetMessageBoxStandard("Ошибка", "Выберите роль.", MsgButton.Ok, MsgIcon.Info)
                    .ShowWindowDialogAsync(this);

                return;
            }

            if (_currentUser.Id == Guid.Empty)
            {
                bool isExistLogin = _context.Users.Any(x => x.Login == _currentUser.Login);

                if (isExistLogin)
                {
                    MsgBox
                        .GetMessageBoxStandard("Ошибка", "Данный логин есть в системе.", MsgButton.Ok, MsgIcon.Info)
                        .ShowWindowDialogAsync(this);

                    return;
                }

                _currentUser.Id = Guid.NewGuid();
                _currentUser.RoleId = selectedRole.Id;
                _currentUser.Role = selectedRole;

                _context.Users.Add(_currentUser);
            }
            else
            {
                _currentUser.RoleId = selectedRole.Id;
                _currentUser.Role = selectedRole;

                _context.Users.Update(_currentUser);
            }

            _context.SaveChanges();
            Close();
        }
        catch
        {
            MsgBox
                .GetMessageBoxStandard("Ошибка", "Ошибка сохранения пользователя.", MsgButton.Ok, MsgIcon.Error)
                .ShowWindowDialogAsync(this);
        }
    }
}
