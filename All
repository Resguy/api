CREATE TABLE Customers (
    id SERIAL PRIMARY KEY,
    name VARCHAR(50) NOT NULL,
    inn VARCHAR(12),
    Addres VARCHAR(200),
    Phone VARCHAR(20) NOT NULL,
    Salesman BOOLEAN NOT NULL,
    Buyer BOOLEAN NOT NULL
);

CREATE TABLE UnitTypes(
    UnitTypeID SERIAL PRIMARY KEY,
    UnitTypesName VARCHAR(12) NOT NULL
);

CREATE TABLE Makers(
	MakerID SERIAL PRIMARY KEY,
	MakerName VARCHAR(50) NOT NULL,
	INN VARCHAR(12) NOT NULL,
	PhoneNumber VARCHAR(20) NOT NULL
);

CREATE TABLE Materials (
    MaterialID SERIAL PRIMARY KEY,
    Code VARCHAR(6) NOT NULL,
    Quantity INT NOT NULL,
	UnitTypeID INT REFERENCES UnitTypes(UnitTypeID),
	MakerID INT REFERENCES Makers(MakerID),
    Price DECIMAL(10, 2) NOT NULL
);

CREATE TABLE Products (
	ProductID SERIAL PRIMARY KEY,
	Code VARCHAR(6) NOT NULL,
	Quantity INT NOT NULL,
	UnitTypeID INT REFERENCES UnitTypes(UnitTypeID),
	MakerID INT REFERENCES Makers(MakerID)
);

CREATE TABLE ProductMaterials (
	ProductID INT REFERENCES Products(ProductID),
	MaterialID INT REFERENCES Materials(MaterialID),
	Quantity INT NOT NULL
);

CREATE TABLE Executors (
	ExecutorID SERIAL PRIMARY KEY,
	ExecutorName VARCHAR(50) NOT NULL,
	INN VARCHAR(12) NOT NULL,
	PhoneNumber VARCHAR(20) NOT NULL
);

CREATE TABLE Orders (
    OrderID SERIAL PRIMARY KEY,
	ExecutorID INT REFERENCES Executors(ExecutorID),
	id INT REFERENCES Customers(id)
);

CREATE TABLE OrderPositions (
	OrderID INT REFERENCES Orders(OrderID),
	ProductID INT REFERENCES Products(ProductID),
	Quantity INT NOT NULL
);

