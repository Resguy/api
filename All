using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Interactivity;
using Avalonia.Media;
using Avalonia.Media.Imaging;
using DEMO.Models;
using Microsoft.EntityFrameworkCore;
using System;
using System.IO;
using System.Linq;
using MsgBox = MsBox.Avalonia.MessageBoxManager;
using MsgButton = MsBox.Avalonia.Enums.ButtonEnum;
using MsgIcon = MsBox.Avalonia.Enums.Icon;

namespace DEMO;

public partial class MainWindow : Window
{
    private readonly AppDbContext _context = new();

    private Border[] _cells = Array.Empty<Border>();

    private Bitmap[] _images = Array.Empty<Bitmap>();

    private int[] _orders = { 0, 1, 2, 3 };

    private int failedAttempts = 0;

    public MainWindow()
    {
        InitializeComponent();
        LoadCaptcha();
    }

    private void LoadCaptcha()
    {
        _cells = new[] { Cell0, Cell1, Cell2, Cell3 };

        string imageDirectory = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Captcha");

        _images = Enumerable.Range(1, 4)
            .Select(x => new Bitmap(Path.Combine(imageDirectory, $"{x}.png")))
            .ToArray();

        for (int i = 0; i < _cells.Length; i++)
        {
            int index = i;

            _cells[i].PointerPressed += async (sender, e) =>
            {
                var data = new DataObject();
                data.Set("CurrentIndex", index);
                await DragDrop.DoDragDrop(e, data, DragDropEffects.Move);
            };

            _cells[i].AddHandler(DragDrop.DropEvent, (s, e) => OnDrop(index, e));
            _cells[i].AddHandler(DragDrop.DragOverEvent, (s, e) => e.DragEffects = DragDropEffects.Move);
        }

        Shuffle();
    }

    private void Shuffle()
    {
        _orders = _orders.OrderBy(x => Guid.NewGuid()).ToArray();
        DrawCaptcha();
    }

    private void DrawCaptcha()
    {
        for (int i = 0; i < _cells.Length; i++)
        {
            _cells[i].Child = new Image
            {
                Source = _images[_orders[i]],
                Stretch = Stretch.Fill
            };
        }
    }

    private void OnDrop(int to, DragEventArgs e)
    {
        if (!e.Data.Contains("CurrentIndex"))
            return;

        int from = (int)e.Data.Get("CurrentIndex")!;

        if (from == to)
            return;

        (_orders[from], _orders[to]) = (_orders[to], _orders[from]);

        DrawCaptcha();
    }

    private void ShuffleButton_Click(object? sender, RoutedEventArgs e)
    {
        Shuffle();
    }

    private void EnterButton_Click(object? sender, RoutedEventArgs e)
    {
        Auth(TbLogin.Text, TbPassword.Text);
    }

    private void Auth(string? login, string? password)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(login) || string.IsNullOrWhiteSpace(password))
            {
                MsgBox
                    .GetMessageBoxStandard("Ошибка", "Логин и пароль являются обязательными полями.", MsgButton.Ok, MsgIcon.Info)
                    .ShowWindowDialogAsync(this);

                return;
            }

            var user = _context.Users
                .Include(x => x.Role)
                .SingleOrDefault(x => x.Login == login);

            if (user == null || user.Password != password)
            {
                failedAttempts++;

                MsgBox
                    .GetMessageBoxStandard("Ошибка", "Вы ввели неверный логин или пароль. Пожалуйста проверьте ещё раз введенные данные.", MsgButton.Ok, MsgIcon.Info)
                    .ShowWindowDialogAsync(this);

                if (user != null)
                    CheckBlock(user);

                return;
            }

            if (user.IsBlocked)
            {
                MsgBox
                    .GetMessageBoxStandard("Ошибка", "Вы заблокированы. Обратитесь к администратору.", MsgButton.Ok, MsgIcon.Info)
                    .ShowWindowDialogAsync(this);

                return;
            }

            if (!_orders.SequenceEqual(new[] { 0, 1, 2, 3 }))
            {
                failedAttempts++;
                Shuffle();
                CheckBlock(user);
                return;
            }

            failedAttempts = 0;

            MsgBox
                .GetMessageBoxStandard("Информация", "Вы успешно авторизовались.", MsgButton.Ok, MsgIcon.Info)
                .ShowWindowDialogAsync(this);

            if (user.Role != null && user.Role.Name == "Админ")
            {
                new AdminPanel().Show();
                Close();
            }
        }
        catch
        {
            MsgBox
                .GetMessageBoxStandard("Ошибка", "Произошла ошибка при авторизации.", MsgButton.Ok, MsgIcon.Error)
                .ShowWindowDialogAsync(this);
        }
    }

    private void CheckBlock(User user)
    {
        if (failedAttempts >= 3)
        {
            user.IsBlocked = true;
            _context.SaveChanges();

            MsgBox
                .GetMessageBoxStandard("Ошибка", "Вы заблокированы. Обратитесь к администратору.", MsgButton.Ok, MsgIcon.Info)
                .ShowWindowDialogAsync(this);
        }
    }
}
